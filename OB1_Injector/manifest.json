{
  "manifest_version": 3,
  "name": "OB1 Injector",
  "version": "1.0",
  "description": "OB1 Memory System — injects session digest into claude.ai at session start.",
  "permissions": [],
  "host_permissions": [
    "https://claude.ai/*",
    "https://ob1.jsglabs.com/*",
    "http://192.168.1.41/*",
    "http://100.105.169.111/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["ob1_injector.js"],
      "run_at": "document_idle"
    }
  ]
}
